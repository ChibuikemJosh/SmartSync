{
  "expo": {
    "name": "SmartSync",
    "slug": "smartsync",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.smartsync.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.smartsync.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SmartSync to access your camera"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow SmartSync to access your microphone"
        }
      ]
    ],
    "extra": {
      "apiUrl": "http://localhost:8000/api"
    }
  }
}
