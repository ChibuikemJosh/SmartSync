**/.plugin_symlinks/

# --- Git ---
.git
.gitignore
.gitattributes

# --- IDEs & OS Files ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Logs & Temp ---
*.log
logs/
tmp/
