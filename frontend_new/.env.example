# SmartSync Flutter App - Configuration

## API Configuration
# Set your backend API IP/URL
# Make sure the backend is running on this address
API_BASE_URL=http://192.168.1.100:8000

# For development
API_BASE_URL_DEV=http://localhost:8000

# For production
API_BASE_URL_PROD=https://api.smartsync.ng

## App Configuration
APP_NAME=SmartSync
APP_VERSION=1.0.0
BUILD_NUMBER=1

## Feature Flags
ENABLE_VOICE_INPUT=true
ENABLE_OCR=true
ENABLE_AI_CHAT=true
ENABLE_ANALYTICS=false

## Logging
LOG_LEVEL=DEBUG
ENABLE_LOG_FILE=false

## Security
ENABLE_SSL_PINNING=false
SESSION_TIMEOUT=3600

## Authentication
AUTO_LOGIN_ENABLED=false
BIOMETRIC_ENABLED=true

## Notification
ENABLE_PUSH_NOTIFICATIONS=true
NOTIFICATION_TIMEOUT=30

## Performance
API_TIMEOUT=30000
IMAGE_CACHE_SIZE=100
MAX_RETRY_ATTEMPTS=3

## UI
THEME=light
USE_DARK_MODE=false
ANIMATION_ENABLED=true
