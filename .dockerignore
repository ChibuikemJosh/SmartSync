# Exclude local virtual environments and Python caches
venv/
backend/venv/
.venv/
__pycache__/
*.py[cod]

# Node modules and build artifacts
node_modules/
frontend/node_modules/
frontend/temp-app/node_modules/
frontend_new/**/build/
frontend_new/**/ephemeral/

# Flutter and Dart caches
build/
/.dart_tool/
/.flutter-plugins
/.flutter-plugins-dependencies

# IDE and editor files
.vscode/
.idea/

# Plugin symlinks and pub cache
**/.plugin_symlinks/
.pub-cache/

# Git
.git

# Environment files
.env
.env.*

# Misc
*.log
tmp/
dist/